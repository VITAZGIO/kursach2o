@model RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
}

<h1>Регистрация</h1>
<div class="content-block">
    <form asp-action="Register" method="post" class="form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-row"><label asp-for="Login"></label><input asp-for="Login" /><span asp-validation-for="Login" class="text-danger"></span></div>
        <div class="form-row"><label asp-for="Password"></label><input asp-for="Password" /><span asp-validation-for="Password" class="text-danger"></span></div>
        <div class="form-row"><label asp-for="FullName"></label><input asp-for="FullName" /><span asp-validation-for="FullName" class="text-danger"></span></div>
        <div class="form-row"><label asp-for="Phone"></label><input asp-for="Phone" /></div>
        <div class="form-row"><label asp-for="Email"></label><input asp-for="Email" /><span asp-validation-for="Email" class="text-danger"></span></div>
        <div class="form-row"><label asp-for="Address"></label><textarea asp-for="Address"></textarea></div>
        <button class="btn" type="submit">Зарегистрироваться</button>
        <a class="btn secondary" asp-action="Login">Вход</a>
    </form>
</div>
