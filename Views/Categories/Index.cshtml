@model IEnumerable<Category>
@{
    ViewData["Title"] = "Категории";
    var isAdmin = Context.Session.GetString("Role") == "Admin";
}

<div class="toolbar">
    <h1>Категории</h1>
    @if (isAdmin)
    {
        <a class="btn" asp-action="Create">Добавить</a>
    }
</div>
<table class="table">
    <thead><tr><th>Название</th><th>Описание</th><th>Действия</th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Description</td>
            <td class="actions">
                <a class="btn secondary" asp-action="Details" asp-route-id="@item.Id">Подробнее</a>
                @if (isAdmin)
                {
                    <a class="btn secondary" asp-action="Edit" asp-route-id="@item.Id">Изменить</a>
                    <a class="btn danger" asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
