@model Customer
@{ ViewData["Title"] = "Удалить клиента"; }
<h1>Удалить клиента</h1>
<div class="content-block"><p>Вы действительно хотите удалить клиента <strong>@Model.FullName</strong>?</p><form asp-action="Delete" method="post"><input type="hidden" asp-for="Id" /><button class="btn danger" type="submit">Удалить</button> <a class="btn secondary" asp-action="Index">Назад</a></form></div>
