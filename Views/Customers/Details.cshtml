@model Customer
@{ ViewData["Title"] = "Подробнее"; }
<h1>@Model.FullName</h1>
<div class="content-block"><dl class="details-list"><dt>ФИО</dt><dd>@Model.FullName</dd><dt>Телефон</dt><dd>@Model.Phone</dd><dt>Email</dt><dd>@Model.Email</dd><dt>Адрес</dt><dd>@Model.Address</dd></dl><a class="btn" asp-action="Edit" asp-route-id="@Model.Id">Изменить</a> <a class="btn secondary" asp-action="Index">Назад</a></div>
