@model Customer
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<input type="hidden" asp-for="Id" />
<div class="form-row"><label asp-for="FullName"></label><input asp-for="FullName" /><span asp-validation-for="FullName" class="text-danger"></span></div>
<div class="form-row"><label asp-for="Phone"></label><input asp-for="Phone" /></div>
<div class="form-row"><label asp-for="Email"></label><input asp-for="Email" /><span asp-validation-for="Email" class="text-danger"></span></div>
<div class="form-row"><label asp-for="Address"></label><textarea asp-for="Address"></textarea></div>
