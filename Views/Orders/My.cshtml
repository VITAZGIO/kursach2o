@model IEnumerable<Order>
@{
    ViewData["Title"] = "Мои заказы";
}

<h1>Мои заказы</h1>
<table class="table">
    <thead>
        <tr>
            <th>Номер заказа</th>
            <th>Дата</th>
            <th>Время</th>
            <th>Статус</th>
            <th>Сумма</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        var statusClass = item.Status == "Выполнен" ? "status-done" : "status-processing";
        <tr>
            <td class="nowrap">№@item.Id</td>
            <td class="nowrap">@item.OrderDate.ToString("dd.MM.yyyy")</td>
            <td class="nowrap">@item.OrderDate.ToString("HH:mm")</td>
            <td><span class="status-badge @statusClass">@item.Status</span></td>
            <td class="nowrap">@item.TotalAmount.ToString("N2") ₽</td>
            <td><a class="btn secondary" asp-action="Details" asp-route-id="@item.Id">Подробнее</a></td>
        </tr>
    }
    </tbody>
</table>
