@model Order
@{
    ViewData["Title"] = "Подробнее";
    var isAdmin = Context.Session.GetString("Role") == "Admin";
    var statusClass = Model.Status == "Выполнен" ? "status-done" : "status-processing";
}

<div class="toolbar">
    <h1>Заказ №@Model.Id</h1>
</div>

<div class="content-block">
    <h2>Информация о заказе</h2>
    <dl class="details-list">
        <dt>Клиент</dt><dd>@Model.Customer?.FullName</dd>
        <dt>Телефон</dt><dd>@Model.Customer?.Phone</dd>
        <dt>Email</dt><dd>@Model.Customer?.Email</dd>
        <dt>Адрес</dt><dd>@Model.Customer?.Address</dd>
        <dt>Дата и время</dt><dd>@Model.OrderDate.ToString("dd.MM.yyyy HH:mm")</dd>
        <dt>Статус</dt><dd><span class="status-badge @statusClass">@Model.Status</span></dd>
    </dl>
</div>

<h2>Список мебели</h2>
<table class="table">
    <thead>
        <tr>
            <th>Мебель</th>
            <th>Количество</th>
            <th>Цена</th>
            <th>Сумма по позиции</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.OrderItems)
    {
        <tr>
            <td>@item.FurnitureItem?.Name</td>
            <td class="nowrap">@item.Quantity</td>
            <td class="nowrap">@item.UnitPrice.ToString("N2") ₽</td>
            <td class="nowrap">@((item.Quantity * item.UnitPrice).ToString("N2")) ₽</td>
        </tr>
    }
    </tbody>
</table>

<div class="content-block">
    <h2>Общая сумма: @Model.TotalAmount.ToString("N2") ₽</h2>
    @if (isAdmin)
    {
        <a class="btn secondary" asp-action="Index">Назад</a>
    }
    else
    {
        <a class="btn secondary" asp-action="My">Назад</a>
    }
</div>
