@model FurnitureItem
@{
    ViewData["Title"] = "Изменить мебель";
}

<h1>Изменить мебель</h1>
<form asp-action="Edit" method="post" enctype="multipart/form-data" class="form">
    <partial name="_Form" model="Model" />
    <button class="btn" type="submit">Сохранить</button>
    <a class="btn secondary" asp-action="Index">Назад</a>
</form>
