@model IEnumerable<OrderItem>
@{
    ViewData["Title"] = "Позиции заказов";
}

<div class="toolbar">
    <h1>Позиции заказов</h1>
    <a class="btn" asp-action="Create">Добавить</a>
</div>
<table class="table">
    <thead><tr><th>Заказ</th><th>Мебель</th><th>Количество</th><th>Цена</th><th>Действия</th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>№@item.OrderId</td>
            <td>@item.FurnitureItem?.Name</td>
            <td>@item.Quantity</td>
            <td>@item.UnitPrice.ToString("N2") ₽</td>
            <td class="actions">
                <a class="btn secondary" asp-action="Edit" asp-route-id="@item.Id">Изменить</a>
                <a class="btn secondary" asp-action="Details" asp-route-id="@item.Id">Подробнее</a>
                <a class="btn danger" asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
            </td>
        </tr>
    }
    </tbody>
</table>
